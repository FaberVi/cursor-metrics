{
  "name": "cursor-usage",
  "displayName": "Cursor Usage (Community)",
  "description": "Shows your Cursor IDE usage (included requests and on-demand spend) in the status bar",
  "version": "0.8.0",
  "publisher": "fabervi",
  "license": "MIT",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/FaberVi/cursor-metrics"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "icon": "icon.png",
  "contributes": {
    "commands": [
      {
        "command": "cursor-usage.showDetails",
        "title": "Cursor Usage (Community): Show Details"
      },
      {
        "command": "cursor-usage.refresh",
        "title": "Cursor Usage (Community): Refresh"
      },
      {
        "command": "cursor-usage.openDashboard",
        "title": "Cursor Usage (Community): Open Dashboard"
      }
    ],
    "configuration": {
      "title": "Cursor Usage (Community)",
      "properties": {
        "cursorUsage.pollInterval": {
          "type": "number",
          "default": 5,
          "enum": [
            1,
            5,
            10,
            30,
            60
          ],
          "enumDescriptions": [
            "Every 1 minute",
            "Every 5 minutes",
            "Every 10 minutes",
            "Every half hour",
            "Every hour"
          ],
          "description": "How often to refresh usage data (in minutes)"
        },
        "cursorUsage.minimalMode": {
          "type": "boolean",
          "default": false,
          "description": "Show only the active metric: premium requests if not exhausted, or credits if premium is used up"
        },
        "cursorUsage.usageDuration": {
          "type": "string",
          "default": "billingCycle",
          "enum": [
            "1d",
            "7d",
            "30d",
            "billingCycle"
          ],
          "enumItemLabels": [
            "Last 24 hours",
            "Last 7 days",
            "Last 30 days",
            "Current Billing Cycle"
          ],
          "enumDescriptions": [
            "Last 24 hours",
            "Last 7 days",
            "Last 30 days",
            "Current billing cycle (falls back to Last 30 Days when reset metadata is unavailable)"
          ],
          "description": "Time range for the usage-by-model breakdown in the tooltip. Current Billing Cycle falls back to Last 30 Days when reset metadata is unavailable."
        },
        "cursorUsage.modelBreakdownSortBy": {
          "type": "string",
          "default": "tokens",
          "enum": [
            "model",
            "requests",
            "tokens",
            "spend"
          ],
          "enumItemLabels": [
            "Model",
            "Requests",
            "Tokens",
            "Spend"
          ],
          "description": "Sort column for the usage-by-model table."
        },
        "cursorUsage.modelBreakdownSortOrder": {
          "type": "string",
          "default": "desc",
          "enum": [
            "asc",
            "desc"
          ],
          "enumItemLabels": [
            "Ascending",
            "Descending"
          ],
          "description": "Sort direction for the usage-by-model table."
        },
        "cursorUsage.excludeZeroTokenModels": {
          "type": "boolean",
          "default": false,
          "description": "Hide rows in the usage-by-model table where token usage is zero."
        },
        "cursorUsage.quotaAwareEventDisplay": {
          "type": "boolean",
          "default": true,
          "description": "In the dashboard, show included usage as requests and on-demand usage as spend instead of showing raw request and spend values for every event."
        }
      }
    }
  },
  "scripts": {
    "build": "bun scripts/download-chart.mjs && bun esbuild.config.mjs --production",
    "watch": "bun esbuild.config.mjs --watch",
    "package": "bun scripts/package-extension.mjs",
    "package:vsm": "bun scripts/package-extension.mjs vsm",
    "publish:ovsx": "bun scripts/publish-extension.mjs ovsx",
    "publish:vsm": "bun run package:vsm && bun scripts/publish-extension.mjs vsm",
    "publish:all": "bun run package && bun run publish:ovsx && bun run publish:vsm",
    "release": "bun run publish:all",
    "screenshots": "bun scripts/capture-screenshots.mjs"
  },
  "dependencies": {
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.25.0",
    "playwright": "^1.52.0",
    "puppeteer": "^25.3.0",
    "typescript": "^5.7.0"
  }
}
